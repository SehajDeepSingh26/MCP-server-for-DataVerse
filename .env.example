# Dynamics 365 Connection Settings

# Required: Your Dynamics 365 organization URL
D365_URL=https://your-org.crm.dynamics.com

# Azure AD Authentication (Option 1: Service Principal)
D365_TENANT_ID=your-tenant-id
D365_CLIENT_ID=your-client-id
D365_CLIENT_SECRET=your-client-secret

# Connection String Authentication (Option 2: Alternative)
# D365_CONNECTION_STRING=AuthType=ClientSecret;Url=https://your-org.crm.dynamics.com;ClientId=your-client-id;ClientSecret=your-client-secret;TenantId=your-tenant-id

# Optional: Logging and Cache
LOG_LEVEL=info
CACHE_TTL_SECONDS=300

# Optional: Test Plugin Settings
D365_TEST_PLUGIN_ASSEMBLY_NAME=TestPluginAssembly
D365_TEST_PLUGIN_TYPE_NAME=TestPlugin