{
  "name": "mcp-d365-dev-toolkit",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Dynamics 365 development tools",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.cjs",
    "test:integration": "jest --config jest.config.cjs --testPathPattern=integration",
    "test:integration:plugins": "jest --config jest.config.cjs --runInBand tests/integration/plugins.tools.integration.test.ts",
    "test:watch": "jest --config jest.config.cjs --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "dev": "nodemon server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dynamics-365",
    "d365",
    "power-platform",
    "dataverse",
    "ai",
    "copilot"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.13.6",
    "dotenv": "^16.3.0",
    "dynamics-web-api": "^2.3.0",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
